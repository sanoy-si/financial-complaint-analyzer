# Copy to .env and fill in. NEVER commit a real .env (the repo is public).

ENVIRONMENT=development
PRODUCT_NAME=Grounded

# API
CORS_ORIGINS=["http://localhost:3000"]

# Database (local docker-compose default)
DATABASE_URL=postgresql+psycopg://grounded:grounded@localhost:5432/grounded

# Auth — generate a strong secret for any real deployment
JWT_SECRET=change-me

# Embeddings: hash (no deps, default) or sentence_transformers (local model)
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Generation: mock (free demo default) | openai | groq | gemini | anthropic | ollama
LLM_PROVIDER=mock
LLM_MODEL=
LLM_API_KEY=
